{
  "name": "@cyanheads/nws-weather-mcp-server",
  "version": "0.5.12",
  "description": "Get US weather forecasts, active alerts, and current observations via the National Weather Service API. STDIO or Streamable HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nws-weather-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "lint:packaging": "bun scripts/lint-packaging.ts",
    "changelog:build": "bun scripts/build-changelog.ts",
    "changelog:check": "bun scripts/build-changelog.ts --check",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "test": "vitest run",
    "list-skills": "bun scripts/list-skills.ts",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js",
    "bundle": "bun run build && npx -y @anthropic-ai/mcpb pack . dist/nws-weather-mcp-server.mcpb",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish"
  },
  "mcpName": "io.github.cyanheads/nws-weather-mcp-server",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "weather",
    "nws",
    "national-weather-service",
    "forecast",
    "alerts",
    "observations",
    "typescript",
    "bun",
    "stdio",
    "streamable-http"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/nws-weather-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/nws-weather-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/nws-weather-mcp-server/issues"
  },
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/nws-weather-mcp-server#readme)",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.9.13",
    "@opentelemetry/api": "^1.9.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "@vitest/coverage-istanbul": "^4.1.7",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
