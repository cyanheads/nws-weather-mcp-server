{
  "name": "nws-weather-mcp-server",
  "version": "0.6.2",
  "description": "Get US weather forecasts, active alerts, and current observations via the National Weather Service API. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/nws-weather-mcp-server#readme",
  "repository": "https://github.com/cyanheads/nws-weather-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "nws-weather-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/nws-weather-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
